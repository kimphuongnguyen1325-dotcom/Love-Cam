/* 💖 tim 3D */
.hearts div {
  filter: drop-shadow(0 0 10px pink);
  transform: perspective(200px);
}

/* ✨ nền mượt */
body {
  background: radial-gradient(circle at top, #111, #000);
}

/* 🌌 overlay mờ */
#intro, #choice, #typing, #signature {
  text-shadow: 0 0 10px rgba(255,255,255,0.5);
}

/* 💫 hover nút */
button:hover {
  transform: scale(1.1);
  transition: 0.2s;
  cursor: pointer;
}
